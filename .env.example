# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
#
# Usage:
#   cp .env.example .env
#   docker compose up -d

# ──────────────────────────────────────────────────────────────────────────────
# PostgreSQL — used by the postgres container and by the backend DSN below.
# ──────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=netdisk
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=netdisk
POSTGRES_PORT=15432

# ──────────────────────────────────────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────────────────────────────────────
REDIS_PORT=16379
# Optional Redis AUTH password — leave empty if Redis has no password set.
NETDISK_REDIS_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# Backend secrets — consumed by the backend via NETDISK_* env vars (config.go).
# ──────────────────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# Full Postgres DSN read by the backend. Hostname `postgres` is the
# docker-compose service name; keep it `postgres` when running via compose.
NETDISK_DB_DSN=postgres://netdisk:replace-me@postgres:5432/netdisk?sslmode=disable

# JWT signing secret. Generate with: `openssl rand -hex 32`
NETDISK_JWT_SECRET=replace-me-with-a-long-random-string

# OAuth2 callback & frontend URLs — override config.docker.yaml at runtime.
# Use these when the deployment domain differs from the YAML default.
NETDISK_OAUTH2_REDIRECT_BASE_URL=
NETDISK_OAUTH2_FRONTEND_URL=

# OAuth provider credentials — leave empty to disable that provider.
NETDISK_OAUTH2_2LIBRA_CLIENT_ID=
NETDISK_OAUTH2_2LIBRA_CLIENT_SECRET=
NETDISK_OAUTH2_GITHUB_CLIENT_ID=
NETDISK_OAUTH2_GITHUB_CLIENT_SECRET=
