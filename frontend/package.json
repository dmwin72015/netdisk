{
	"name": "netdisk-frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && vite dev",
		"build": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.9.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.7"
	},
	"dependencies": {
		"@fontsource-variable/inter": "5.2.8",
		"@fontsource-variable/jetbrains-mono": "5.2.8",
		"@inlang/paraglide-js": "^2.18.1",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.17.0",
		"@tailwindcss/vite": "^4.3.0",
		"bits-ui": "^2.18.1",
		"hls.js": "^1.6.16",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.0"
	}
}
