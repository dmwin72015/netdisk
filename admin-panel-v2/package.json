{
  "name": "admin-panel-v2",
  "version": "2.0.0",
  "private": true,
  "description": "NetDisk Admin Panel — migrated from UmiJS to Vite + React Router",
  "repository": "git@github.com:your-org/admin-panel-v2.git",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "npm run biome:lint && npm run tsc",
    "lint-staged": "lint-staged",
    "biome:lint": "biome lint",
    "biome": "biome check --write",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "@ant-design/icons": "^6.3.1",
    "@ant-design/plots": "^2.6.8",
    "@ant-design/pro-components": "^3.1.12-0",
    "@ant-design/x": "^2.8.0",
    "@ant-design/x-markdown": "^2.8.0",
    "@ant-design/x-sdk": "^2.8.0",
    "@rc-component/util": "^1.11.0",
    "@tanstack/react-query": "^5.101.0",
    "antd": "^6.5.0",
    "antd-style": "^4.1.0",
    "china-division": "^2.7.0",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "dayjs": "^1.11.20",
    "highlight.js": "^11.11.1",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.4.0",
    "topojson-client": "^3.1.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@ant-design/cli": "^6.5.0",
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7.4.3",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-helmet": "^6.1.11",
    "@types/topojson-client": "^3.1.5",
