    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.2",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  }
